NODE_ENV=development
PORT=3000

# Postgres connection string used both by the app and by node-pg-migrate
DATABASE_URL=postgres://postgres:postgres@localhost:5432/intahe_dev

# JWT signing secret for access tokens
JWT_SECRET=change-me-in-every-environment
JWT_EXPIRES_IN=7d

# Password reset tokens are single-use and expire after this many minutes
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Stripe Connect (destination charges). Use test-mode keys locally; the app
# boots fine with placeholders, but checkout/webhooks will fail without real
# ones since those calls hit the actual Stripe API.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Where Stripe redirects the organizer during Connect onboarding. Replace
# with real frontend routes once one exists.
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/stripe/connect/refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/stripe/connect/return

# Comma-separated OAuth client IDs (iOS/Android/web) — every `aud` value
# POST /v1/auth/google should accept as valid.
GOOGLE_OAUTH_CLIENT_IDS=replace-me.apps.googleusercontent.com

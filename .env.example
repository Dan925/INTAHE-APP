NODE_ENV=development
PORT=3000

# Postgres connection string used both by the app and by node-pg-migrate
DATABASE_URL=postgres://postgres:postgres@localhost:5432/intahe_dev

# JWT signing secret for access tokens
JWT_SECRET=change-me-in-every-environment
JWT_EXPIRES_IN=7d

# Password reset tokens are single-use and expire after this many minutes
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
